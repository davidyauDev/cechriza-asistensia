MODE=environment

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Timezone for the application (used by Carbon and other date helpers)
# Example: APP_TIMEZONE=America/Lima
APP_TIMEZONE=America/Lima

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base externa (PostgreSQL)
DB_PG_HOST=
DB_PG_PORT=
DB_PG_DATABASE=
DB_PG_USERNAME=
DB_PG_PASSWORD=

# Base externa MySQL (Técnicos)
DB_EXTERNAL_HOST=127.0.0.1
DB_EXTERNAL_PORT=3306
DB_EXTERNAL_DATABASE=external_technicians_db
DB_EXTERNAL_USERNAME=root
DB_EXTERNAL_PASSWORD=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cechriza_asistencia
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_ENCRYPTION=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

MAIL_ALT_MAILER=smtp
MAIL_ALT_SCHEME=null
MAIL_ALT_ENCRYPTION=null
MAIL_ALT_HOST=127.0.0.1
MAIL_ALT_PORT=2525
MAIL_ALT_USERNAME=null
MAIL_ALT_PASSWORD=null
MAIL_ALT_FROM_ADDRESS=null
MAIL_ALT_FROM_NAME=null

MAIL_TEST_MAILER=smtp
MAIL_TEST_SCHEME=null
MAIL_TEST_ENCRYPTION=null
MAIL_TEST_HOST=127.0.0.1
MAIL_TEST_PORT=2525
MAIL_TEST_USERNAME=null
MAIL_TEST_PASSWORD=null
MAIL_TEST_FROM_ADDRESS=null
MAIL_TEST_FROM_NAME=null

# Solicitudes completas
SOLICITUD_AREA_COMPRAS_ID=7
PEDIDO_COMPRA_NOTIFY_EMAIL=compras@example.com
SMTP_ALWAYS_CC=
SOLICITUD_COMPRA_RRHH_ROLES=RRHH,ADMIN,SUPER_ADMIN
SOLICITUD_COMPRA_GERENCIA_ROLES=GERENCIA,ADMIN,SUPER_ADMIN
SOLICITUD_COMPRA_RRHH_EMAILS=
SOLICITUD_COMPRA_GERENCIA_EMAILS=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
